## GitHub Pages base path (usually "/<repo>/")
VITE_SITE_BASE=/circuitcindy-studios/

## Firebase Realtime Database (required for Kirby pet counter)
## Create a Firebase project, enable Realtime Database, then fill these in.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# GitHub Project Pages — must match /<your-repo>/ (include leading and trailing slash).
# (`npm run dev` ignores this — Vite uses base "/" locally so localhost:5173 works.)
# Copy to `.env` (do not commit) and paste values from Firebase → Project settings.
VITE_SITE_BASE=/cat-site/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# After creating the Firebase Realtime Database, publish `database.rules.json`
# via the Firebase Console (Realtime Database → Rules) or `firebase deploy --only database`.
